# Server port (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=development

# REQUIRED: Anthropic API key for the scoring endpoint
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: which Claude model to use for scoring
# Default: claude-sonnet-4-5-20250929
SCORING_MODEL=

# Admin API key for /api/admin/* endpoints (manual edits, deletes, reseed)
# Generate one: openssl rand -hex 32
ADMIN_API_KEY=

# Optional: where to persist data. Default is ./data
# On Railway, attach a volume and set this to the mount path (e.g. /app/data)
DATA_DIR=
